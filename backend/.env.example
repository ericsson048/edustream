DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
TZ=Africa/Johannesburg

# Database (SQLite for local dev, PostgreSQL in production)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_BASE_URL=http://127.0.0.1:3000

# AI
GEMINI_API_KEY=

# Channels / Redis
USE_REDIS_CHANNELS=true
CHANNEL_BACKEND=channels_redis.core.RedisChannelLayer
REDIS_URL=redis://127.0.0.1:6379/0

# Cache
USE_REDIS_CACHE=true
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
DJANGO_CACHE_URL=redis://127.0.0.1:6379/1
DJANGO_CACHE_KEY_PREFIX=edustream
DJANGO_CACHE_TIMEOUT=300
